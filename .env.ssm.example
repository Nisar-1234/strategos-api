# .env.ssm.example — template showing SSM-pulled variables
# Generated by: python3 scripts/ec2-pull-ssm-env.py --output .env.ssm
# On EC2, the instance role (strategos-ec2-ssm-role) provides credentials automatically.
#
# Create a blank file to satisfy Docker Compose before SSM is populated:
#   printf '\n' > .env.ssm
#
# Once real secrets are in Parameter Store (/strategos/prod/*), run:
#   export AWS_REGION=us-east-1
#   python3 scripts/ec2-pull-ssm-env.py --output .env.ssm
#   docker compose -f docker-compose.prod.yml up -d --force-recreate api worker beat

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NEWSAPI_KEY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_CHANNELS=
NASA_FIRMS_MAP_KEY=
ALPHA_VANTAGE_KEY=
METALS_API_KEY=
OPEN_EXCHANGE_RATES_KEY=
CLOUDFLARE_RADAR_TOKEN=
POLYGON_API_KEY=
CORS_ORIGINS=
