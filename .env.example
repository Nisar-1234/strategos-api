# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://strategos:strategos@localhost:5432/strategos
DATABASE_URL_SYNC=postgresql://strategos:strategos@localhost:5432/strategos

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM Keys (at least one for AI chat) ────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── L2 Telegram (primary social — conflict monitoring) ─
TELEGRAM_API_ID=           # https://my.telegram.org/apps (integer)
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=   # from: python scripts/telegram_session_setup.py
TELEGRAM_CHANNELS=         # comma-separated @channel or numeric IDs

# ─── L8 NASA FIRMS (thermal anomalies — free MAP key) ───
NASA_FIRMS_MAP_KEY=        # https://firms.modaps.eosdis.nasa.gov/api/map_key/

# ─── Signal Layer API Keys ──────────────────────────────
NEWSAPI_KEY=               # L1 Editorial — newsapi.org
POLYGON_API_KEY=           # L7 Equities — polygon.io
ALPHA_VANTAGE_KEY=         # L5 Commodities — alphavantage.co
METALS_API_KEY=            # L5 Commodities — metals-api.com
OPEN_EXCHANGE_RATES_KEY=   # L6 Currency — openexchangerates.org
CLOUDFLARE_RADAR_TOKEN=    # L10 Connectivity — radar.cloudflare.com
FRED_API_KEY=              # L9 Economic — free at fred.stlouisfed.org/docs/api/api_key.html

# ─── Frontend / Maps ───────────────────────────────────
MAPBOX_TOKEN=              # Geo Map — mapbox.com

# ─── Vector Store ───────────────────────────────────────
PINECONE_API_KEY=

# ─── Auth0 (optional for dev) ──────────────────────────
AUTH0_DOMAIN=
AUTH0_API_AUDIENCE=
