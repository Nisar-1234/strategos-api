# Database
DATABASE_URL=postgresql+asyncpg://strategos:strategos@localhost:5432/strategos
DATABASE_URL_SYNC=postgresql://strategos:strategos@localhost:5432/strategos

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=gpt-4o

# Signal Layer APIs
NEWSAPI_KEY=xxxxx
POLYGON_API_KEY=xxxxx
ALPHA_VANTAGE_KEY=xxxxx
METALS_API_KEY=xxxxx
OPEN_EXCHANGE_RATES_KEY=xxxxx
CLOUDFLARE_RADAR_TOKEN=xxxxx

# Maps
MAPBOX_TOKEN=pk.xxxxx

# Vector Store
PINECONE_API_KEY=xxxxx

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://api.strategos.platform

# CORS
CORS_ORIGINS=["http://localhost:3000"]
